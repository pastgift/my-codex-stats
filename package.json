{
  "name": "my-codex-stats",
  "author": "pastgift",
  "publisher": "pastgift",
  "displayName": "My Codex Stats",
  "description": "Codex Stats Monitor in Status Bar",
  "repository": {
    "type": "git",
    "url": "https://github.com/pastgift/my-codex-stats"
  },
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Visualization"
  ],
  "icon": "resources/blossom.dark.png",
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "icons": {
      "codex-blossom": {
        "description": "Codex Blossom Icon",
        "default": {
          "fontPath": "resources/codex-icon.woff",
          "fontCharacter": "\\e900"
        }
      }
    },
    "commands": [
      {
        "command": "codex-usage.refresh",
        "title": "Refresh My Codex Stats"
      },
      {
        "command": "codex-usage.login",
        "title": "Login to Codex"
      }
    ],
    "configuration": {
      "title": "My Codex Stats",
      "properties": {
        "codexUsage.updateInterval": {
          "type": "number",
          "default": 300,
          "description": "Update interval in seconds (default: 300 = 5 minutes)"
        },
        "codexUsage.showNotifications": {
          "type": "boolean",
          "default": false,
          "description": "Show notifications when rate limits are high"
        },
        "codexUsage.proxyUrl": {
          "type": "string",
          "default": "",
          "description": "Proxy URL for Codex API requests, for example http://127.0.0.1:7890. Leave empty to connect directly."
        },
        "codexUsage.model": {
          "type": "string",
          "default": "gpt-5.4-mini",
          "description": "Model slug used for minimal Codex API requests. Use a model supported by your ChatGPT Codex account."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "vscode:publish": "vsce publish",
    "compile": "tsc -p ./",
    "vscode:package": "vsce package",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/node": "16.x",
    "@types/vscode": "^1.74.0",
    "@typescript-eslint/eslint-plugin": "^5.45.0",
    "@typescript-eslint/parser": "^5.45.0",
    "eslint": "^8.28.0",
    "typescript": "^4.9.3"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "vsce": "^2.15.0"
  }
}
